# ============================================================================
# Saṃśodhakaḥ — Environment Configuration
# ============================================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=Saṃśodhakaḥ
APP_VERSION=0.1.0
DEBUG=false

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info
CORS_ORIGINS=["*"]

# ── LLM Providers (Optional — only configure what you use) ──
# Mistral AI — required for article generation & summarization
MISTRAL_API_KEY=

# Groq — alternative provider for summarization
GROQ_API_KEY=

# OpenAI — alternative provider
OPENAI_API_KEY=

# ── Web Search (Optional) ───────────────────────────────────
# Serper API — premium fallback when DuckDuckGo is rate-limited
SERPER_API_KEY=